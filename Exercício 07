#include <stdio.h>

int main() {
    int numeros[] = {4, 9, 6, 3, 5, 1, 2, 7};
    int tamanho = sizeof(numeros) / sizeof(numeros[0]);

    printf("Numeros acima de 5:\n");

    for (int i = 0; i < tamanho; i++) {
        if (numeros[i] > 5) {
            printf("%d ", numeros[i]);
        }
    }

    printf("\n");

    return 0;
}
