#include <stdio.h>

int main() {
    int precos[] = {15, 35, 35, 40, 65};
    int tamanho = sizeof(precos) / sizeof(precos[0]);
    int alvo = 70;

    for (int i = 0; i < tamanho; i++) {
        for (int j = i + 1; j < tamanho; j++) {
            if (precos[i] + precos[j] == alvo) {
                printf("Indices encontrados: [%d, %d]\n", i, j);
                return 0; // encerra após encontrar o primeiro par
            }
        }
    }

    printf("Nenhum par encontrado que some ao valor alvo.\n");
    return 0;
}
