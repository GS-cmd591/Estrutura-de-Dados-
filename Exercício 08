#include <stdio.h>

int main() {
    int idades[] = {12, 17, 20, 33, 41, 8, 19};
    int tamanho = sizeof(idades) / sizeof(idades[0]);

    printf("Idades impares:\n");

    for (int i = 0; i < tamanho; i++) {
        if (idades[i] % 2 != 0) {  // verifica se é impar
            printf("%d ", idades[i]);
        }
    }

    printf("\n");

    return 0;
}
